{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "node",
		"outDir": "./dist",
		"baseUrl": "./",
		"paths": {
			"@voltage/config": ["../../packages/config"],
			"@voltage/utils": ["../../packages/utils"]
		},
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"strict": true,
		"resolveJsonModule": true,
		"composite": true,
		"declaration": true
	},
	"include": ["./**/*.ts"],
	"exclude": ["node_modules", "./dist"],
	"references": [{ "path": "../../packages/config" }, { "path": "../../packages/utils" }]
}
