{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"baseUrl": "./",
		"paths": { "@/*": ["src/*"] }
	},
	"include": ["frontend/**/*.ts", "frontend/**/*.tsx", "frontend/src/types/global.d.ts", "frontend/tailwind.config.js"],
	"references": [{ "path": "./frontend/tsconfig.node.json" }]
}
